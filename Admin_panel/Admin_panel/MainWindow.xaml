<Window x:Class="Admin_panel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Admin_panel"
        Title="Admin Panel" Height="700" Width="1000"
        Background="#1E2229">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBackground" Color="#1E2229"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#2D323C"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4A90E2"/>
        <SolidColorBrush x:Key="AccentRed" Color="#E06C75"/>
        <SolidColorBrush x:Key="MainText" Color="#E1E4E8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3E4451"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainText}"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="#252932"/>
            <Setter Property="AlternatingRowBackground" Value="#2D323C"/>
            <Setter Property="Foreground" Value="{StaticResource MainText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#353B45"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#171A1F"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PrimaryBackground}">
        <Grid x:Name="LoginGrid">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                <TextBlock Text="ADMIN LOGIN" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="{StaticResource AccentBlue}"/>
                <TextBlock Text="Username / Email"/>
                <TextBox x:Name="UsernameTextBox"/>
                <TextBlock Text="Password"/>
                <PasswordBox x:Name="PasswordBox"/>
                <Button Content="Login" Click="Login_Click" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Name="UsersGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="CREATE NEW USER" Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="5">
                        <TextBlock Text="Username"/>
                        <TextBox x:Name="CreateUsernameTextBox" Width="180"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Email"/>
                        <TextBox x:Name="CreateEmailTextBox" Width="180"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Password"/>
                        <PasswordBox x:Name="CreatePasswordBox" Width="180"/>
                    </StackPanel>
                    <Button Content="Create User" Click="CreateUser_Click" VerticalAlignment="Bottom" Margin="10,0,0,15"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="UPDATE USER" Margin="5" Grid.Row="1" x:Name="UpdateUserGroupBox" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="5">
                        <TextBlock Text="Username"/>
                        <TextBox x:Name="UpdateUsernameTextBox" Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Email"/>
                        <TextBox x:Name="UpdateEmailTextBox" Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="5">
                        <TextBlock Text="Password"/>
                        <PasswordBox x:Name="UpdatePasswordBox" Width="150"/>
                    </StackPanel>
                    <CheckBox x:Name="UpdateIsAdminCheckBox" Content="Admin" VerticalAlignment="Center" Margin="10,15,10,0" Foreground="White"/>
                    <Button Content="Update User" Click="UpdateUser_Click" VerticalAlignment="Bottom" Margin="0,0,0,15"/>
                </StackPanel>
            </GroupBox>

            <DataGrid Grid.Row="2" Name="DataGrid_Users" ItemsSource="{Binding Users}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding ID}" Header="Id" Width="50"/>
                    <DataGridTextColumn Binding="{Binding Name}" Header="Name" Width="150"/>
                    <DataGridTextColumn Binding="{Binding Email}" Header="Email" Width="200"/>
                    <DataGridCheckBoxColumn Binding="{Binding isAdmin}" Header="Admin" Width="70"/>
                    <DataGridTextColumn Binding="{Binding RegisteredAt}" Header="Registered At" Width="*"/>
                    <DataGridTemplateColumn Header="Actions" Width="260">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Edit" Margin="2" Padding="8,2" Click="EditUser_Click" Background="#56B6C2"/>
                                    <Button Content="Delete" Margin="2" Padding="8,2" Click="DeleteUser_Click" Background="{StaticResource AccentRed}"/>
                                    <Button Content="Scores" Margin="2" Padding="8,2" Click="Scores_Click" Background="#9B59B6"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
