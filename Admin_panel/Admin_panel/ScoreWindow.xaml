<Window x:Class="Admin_panel.ScoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Scores" Height="500" Width="700">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Orientation="Vertical" Margin="0,0,0,10">
			<StackPanel Orientation="Horizontal">
				<StackPanel Margin="5">
					<TextBlock Text="Game Name"/>
					<TextBox x:Name="GamenameTextBox" Width="150"/>
				</StackPanel>

				<StackPanel Margin="5">
					<TextBlock Text="Score"/>
					<TextBox x:Name="ScoreTextBox" Width="100"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="5">
					<Button Content="Add" Click="Add_Click" Margin="5"/>
					<Button Content="Update" Click="Update_Click" Margin="5"/>
					<Button Content="Delete" Click="Delete_Click" Margin="5"/>
				</StackPanel>
			</StackPanel>
		</StackPanel>

		<DataGrid Grid.Row="1" ItemsSource="{Binding Scores}"
                  x:Name="ScoreGrid" AutoGenerateColumns="False">
			<DataGrid.Columns>
				<DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
				<DataGridTextColumn Header="User" Binding="{Binding UserID}" Width="150"/>
				<DataGridTextColumn Header="Score" Binding="{Binding ScoreValue}" Width="100"/>
				<DataGridTextColumn Header="Game" Binding="{Binding Gamename}" Width="*"/>
			</DataGrid.Columns>
		</DataGrid>
	</Grid>
</Window>
